# Copiar a .env en la raíz del repo (junto a docker-compose.yml). NO va dentro de la imagen.
#
# Docker Compose (servicio web) usa env_file: ./.env: inyecta estas variables en el contenedor.
# Django lee DJANGO_DEBUG y DJANGO_SECRET_KEY del entorno del proceso (y read_env como respaldo).
#
# Despliegue en producción:
# - Editar .env en el host: DJANGO_DEBUG=False y DJANGO_SECRET_KEY única
#   (python3 -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
# - Aplicar cambios de .env: docker compose up -d --force-recreate web
#   (restart NO recarga env_file; solo recrea el contenedor con las vars nuevas).
# - Tras cambiar SECRET_KEY, las sesiones existentes caducan (vuelven a iniciar sesión).
# - Opcional: docker compose exec web python manage.py check --deploy

# Configuración de la Base de Datos
DB_HOST=db  # Importante: el host es el nombre del servicio en docker-compose
DB_NAME=tareas_db
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=unacontraseñamuysegura
DB_ROOT_PASSWORD=otracontraseñamuysegura

# Configuración de Django
# Producción: clave larga y secreta; nunca reutilizar valores de ejemplo ni commits viejos.
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=tu-secret-key-aqui
# Producción: False. Desarrollo local: True
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=web.settings

